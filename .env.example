# Copy this file to .env for local Telegram testing.
# Do not commit .env or real tokens.

# Required for scripts/run_telegram_bot.py
telegram_api_token=replace_with_telegram_bot_token

# Optional explainer agent configuration.
# Keep disabled for deterministic/rule-based demo behavior.
explainer_agent_api_token=
explainer_agent_model=gpt-5-nano
explainer_agent_disabled=1
